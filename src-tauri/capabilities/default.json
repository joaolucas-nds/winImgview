{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permissões padrão do WinImgView",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "core:window:allow-toggle-maximize",
    "core:window:allow-start-dragging",
    "core:app:allow-version",
    "shell:allow-open"
  ]
}
